# Cleanroom build validation — see CLEANROOM.md for strategy.
#
# Debian provides ONLY pm runtime (coreutils, curl, tar, etc.).
# All compilers, build tools, and libraries come from Kominka R2.
# This Dockerfile builds all buildable packages from source.
#
# Usage:
#   docker build -t kominka:toolchain -f tests/Dockerfile.toolchain .

FROM debian:bookworm-slim

# pm runtime — download, extract, patch. Nothing else.
RUN apt-get update && apt-get install -y --no-install-recommends \
    coreutils findutils grep sed gawk diffutils \
    curl ca-certificates \
    gzip bzip2 xz-utils tar \
    patch && \
    rm -rf /var/lib/apt/lists/*

# ysh for pm.
RUN curl -fL https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev/aarch64-linux-gnu/ysh@0.37.0-1.tar.gz | \
    tar xzf - -C /

COPY tests/fixtures/repo /packages
RUN find /packages -name build -exec chmod +x {} + && \
    find /packages -name post-install -exec chmod +x {} +
RUN mkdir -p /kominka-root/var/db/kominka/installed /kominka-root/var/db/kominka/choices

ENV KOMINKA_MIRROR=https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev \
    KOMINKA_BIN_MIRROR=https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev \
    KOMINKA_PATH=/packages \
    KOMINKA_ROOT=/kominka-root \
    KOMINKA_COMPRESS=gz \
    KOMINKA_COLOR=0 \
    KOMINKA_PROMPT=0 \
    KOMINKA_STRIP=0 \
    KOMINKA_FORCE=1 \
    LOGNAME=root \
    HOME=/root

COPY pm.ysh /usr/bin/pm
RUN chmod +x /usr/bin/pm

# Install everything from Kominka R2 binaries.
COPY tests/build_core.sh /home/kominka/build_core.sh
RUN chmod +x /home/kominka/build_core.sh && sh /home/kominka/build_core.sh
RUN pm i zig make zlib samurai cmake go

# Fake deps not yet buildable in cleanroom.
RUN for pkg in perl; do \
        mkdir -p "/kominka-root/var/db/kominka/installed/$pkg" && \
        echo "999 1" > "/kominka-root/var/db/kominka/installed/$pkg/version"; \
    done

# Kominka build tools on PATH (after Debian bins so pm uses Debian's curl/tar).
ENV GOROOT=/kominka-root/usr/lib/go \
    PATH=$PATH:/kominka-root/usr/bin:/kominka-root/usr/lib/go/bin \
    CC=/kominka-root/usr/bin/cc \
    CXX=/kominka-root/usr/bin/c++ \
    AR=/kominka-root/usr/bin/ar \
    NM=/kominka-root/usr/bin/nm \
    RANLIB=/kominka-root/usr/bin/ranlib \
    CFLAGS="-I/kominka-root/usr/include" \
    CXXFLAGS="-I/kominka-root/usr/include" \
    LDFLAGS="-L/kominka-root/usr/lib -Wl,-rpath,/kominka-root/usr/lib"

# Phase 2: Build all packages from source.
RUN pm b bzip2 && pm i bzip2
RUN pm b xz && pm i xz
RUN pm b pkgconf && pm i pkgconf
# HACK: flex skipped — stage1flex crashes with SIGPIPE when built with zig cc.
# Needs investigation: may be a zig cc signal handling issue with bootstrapped binaries.
RUN pm b git && pm i git
RUN pm b boringssl && pm i boringssl

# Verify key outputs.
RUN ls /kominka-root/usr/lib/libssl.so /kominka-root/usr/lib/libcrypto.so
RUN ls /kominka-root/usr/bin/git /kominka-root/usr/bin/bzip2 /kominka-root/usr/bin/xz
