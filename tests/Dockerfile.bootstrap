FROM alpine:latest

# Minimal seed: only what's needed to compile C and run pm.
#
# busybox (Alpine base): sh, tar, sed, awk, grep, find, diff,
#   sha256sum, cp, mv, ln, mkdir, rm, cat, head, tail, sort, od, etc.
# gcc + binutils: C compiler, assembler, linker, strip, readelf
# musl-dev: libc headers + crt startup files
# linux-headers: kernel headers (needed by musl and busybox builds)
# make: build system (11 of 16 packages use it)
# patch: busybox build script applies patches (Alpine busybox lacks it)
# cmake, samurai, go: boringssl build system
# bzip2, xz: decompression for source tarballs (.tar.bz2, .tar.xz)
#   (gzip is already in Alpine busybox)
RUN apk add --no-cache \
    gcc binutils musl-dev linux-headers \
    make patch \
    cmake samurai go \
    bzip2 xz

# Install pm.
COPY pm.ysh /usr/bin/pm
RUN chmod +x /usr/bin/pm

# Copy in the vendored repo and sources.
COPY tests/fixtures/repo /home/kominka/repo
COPY tests/fixtures/sources /home/kominka/sources

# Ensure build/post-install scripts are executable.
RUN find /home/kominka/repo -name build -exec chmod +x {} +
RUN find /home/kominka/repo -name post-install -exec chmod +x {} +

# Create the chroot target.
RUN mkdir -p /kominka-root/var/db/kominka/installed /kominka-root/var/db/kominka/choices

# Register host-provided build tools so the package manager's dependency
# resolution finds them as already installed.
RUN for pkg in cmake go samurai; do \
      mkdir -p "/kominka-root/var/db/kominka/installed/$pkg" && \
      echo "0 0" > "/kominka-root/var/db/kominka/installed/$pkg/version"; \
    done

# Add /kominka-root/usr/bin to PATH so that packages built earlier in the
# bootstrap (e.g. m4, make) are available to later builds (e.g. bison).
ENV PATH=/kominka-root/usr/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
    KOMINKA_PATH=/home/kominka/repo \
    KOMINKA_ROOT=/kominka-root \
    KOMINKA_COMPRESS=gz \
    KOMINKA_COLOR=0 \
    KOMINKA_PROMPT=0 \
    KOMINKA_STRIP=0 \
    KOMINKA_FORCE=1 \
    LOGNAME=root \
    HOME=/root \
    CC=gcc \
    PKG_CONFIG_PATH=/kominka-root/usr/lib/pkgconfig \
    CPPFLAGS="-I/kominka-root/usr/include" \
    LDFLAGS="-L/kominka-root/usr/lib"

WORKDIR /home/kominka

COPY tests/build_core.sh /home/kominka/build_core.sh
COPY tests/bootstrap.sh /home/kominka/bootstrap.sh
RUN chmod +x /home/kominka/build_core.sh /home/kominka/bootstrap.sh

# Use tini as PID 1 to reap zombie processes.
RUN apk add --no-cache tini
ENTRYPOINT ["/sbin/tini", "--"]
