# Self-hosting build image — Kominka from scratch with full toolchain.
#
# Stage 1: Install all packages from R2 into /kominka-root using Debian.
# Stage 2: FROM scratch with everything needed to run pm b.
#
# Usage:
#   docker build -t kominka:build -f tests/Dockerfile.selfhost .
#   docker run --rm kominka:build pm b <package>

FROM debian:bookworm-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    coreutils findutils grep sed gawk diffutils \
    curl ca-certificates \
    gzip bzip2 xz-utils tar \
    patch && \
    rm -rf /var/lib/apt/lists/*

RUN curl -fL https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev/aarch64-linux-gnu/ysh@0.37.0-1.tar.gz | \
    tar xzf - -C /

COPY tests/fixtures/repo /packages
RUN find /packages -name build -exec chmod +x {} + && \
    find /packages -name post-install -exec chmod +x {} +
RUN mkdir -p /kominka-root/var/db/kominka/installed /kominka-root/var/db/kominka/choices

ENV KOMINKA_MIRROR=https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev \
    KOMINKA_BIN_MIRROR=https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev \
    KOMINKA_PATH=/packages \
    KOMINKA_ROOT=/kominka-root \
    KOMINKA_COMPRESS=gz \
    KOMINKA_COLOR=0 \
    KOMINKA_PROMPT=0 \
    KOMINKA_STRIP=0 \
    KOMINKA_FORCE=1 \
    LOGNAME=root \
    HOME=/root

COPY pm.ysh /usr/bin/pm
RUN chmod +x /usr/bin/pm

# Install core + full toolchain from R2.
COPY tests/build_core.sh /home/kominka/build_core.sh
RUN chmod +x /home/kominka/build_core.sh && sh /home/kominka/build_core.sh
RUN pm i zig make zlib samurai cmake go bzip2 xz pkgconf git m4 bison linux-headers

# Copy libstdc++ and libgcc_s from host — ysh and cmake need these.
RUN for lib in libstdc++.so.6 libgcc_s.so.1; do \
        src=$(find /lib /usr/lib -name "$lib" 2>/dev/null | head -1); \
        [ -n "$src" ] && cp "$src" /kominka-root/usr/lib/; \
    done

# Copy CA certificates for HTTPS.
RUN cp -r /etc/ssl/certs /kominka-root/etc/ssl/

# Install pm into the chroot.
RUN cp /usr/bin/pm /kominka-root/usr/bin/pm

# Copy package repo.
RUN cp -r /packages /kominka-root/packages

FROM scratch

COPY --from=builder /kominka-root /

ENV PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin \
    HOME=/root \
    LOGNAME=root \
    GOROOT=/usr/lib/go \
    KOMINKA_PATH=/packages \
    KOMINKA_COMPRESS=gz \
    KOMINKA_COLOR=0 \
    KOMINKA_PROMPT=0

CMD ["/bin/sh"]
