# Self-hosting build image — Kominka from scratch with full toolchain.
#
# Bootstrap: busybox:latest (4MB static) provides wget+tar to pull
# Kominka packages from R2. No Debian, no curl, no TLS library.
# Toolchain packages installed via pm inside a chroot.
#
# Usage:
#   docker build -t kominka:build -f tests/Dockerfile.selfhost .
#   docker run --rm kominka:build pm b <package>

FROM busybox:latest AS bootstrap

ARG R2=https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev/aarch64-linux-gnu

# Pull core packages from R2 with busybox wget (no TLS verification).
RUN mkdir -p /kominka-root/var/db/kominka/installed /kominka-root/var/db/kominka/choices && \
    for pkg in \
        baselayout@1-8 \
        glibc@2.38-3 \
        busybox@1.34.1-2 \
        baseinit@1.0.3-1 \
        runit@2.1.2-1 \
        boringssl@0.20260327.0-6 \
        curl@7.80.0-5 \
        opendoas@6.8.1-1 \
        ysh@0.37.0-2; \
    do \
        echo "=== $pkg ===" && \
        wget --no-check-certificate -qO- "$R2/$pkg.tar.gz" | tar xzf - -C /kominka-root; \
    done

# Install pm and package repo.
COPY pm.ysh /kominka-root/usr/bin/pm
RUN chmod +x /kominka-root/usr/bin/pm
COPY tests/fixtures/repo /kominka-root/packages
RUN find /kominka-root/packages -name build -exec chmod +x {} + && \
    find /kominka-root/packages -name post-install -exec chmod +x {} +

# DNS resolution for downloads inside chroot.
RUN cp /etc/resolv.conf /kominka-root/etc/resolv.conf 2>/dev/null || true

# Install toolchain via pm inside the chroot.
# Kominka's curl handles R2 downloads from here on.
RUN chroot /kominka-root /bin/sh -c '\
    export KOMINKA_BIN_MIRROR=https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev \
           KOMINKA_MIRROR=https://pub-ad5257645a73444c9056cf2aed244ac7.r2.dev \
           KOMINKA_PATH=/packages \
           KOMINKA_COMPRESS=gz \
           KOMINKA_COLOR=0 \
           KOMINKA_PROMPT=0 \
           KOMINKA_STRIP=0 \
           KOMINKA_FORCE=1 \
           KOMINKA_INSECURE=1 \
           LOGNAME=root \
           HOME=/root && \
    ysh /usr/bin/pm i zig make zlib samurai cmake go bzip2 xz pkgconf git m4 bison linux-headers'

FROM scratch

COPY --from=bootstrap /kominka-root /

ENV PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin \
    HOME=/root \
    LOGNAME=root \
    GOROOT=/usr/lib/go \
    KOMINKA_PATH=/packages \
    KOMINKA_COMPRESS=gz \
    KOMINKA_COLOR=0 \
    KOMINKA_PROMPT=0

CMD ["/bin/sh"]
