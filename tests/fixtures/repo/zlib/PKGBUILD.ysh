#!/usr/local/bin/ysh

var name    = 'zlib'
var ver     = '1.2.11'
var rel     = '3'
var deps    = []
var mkdeps  = []

var sources = ['https://zlib.net/fossils/zlib-VERSION.tar.gz']
var checksums = ['c3e5e9fdd5004dcb542feda5ee4f0ff0744628baf8ed2dd5d66f8ca1197cb1a1']

proc build(dest) {
    var CFLAGS = ENV => get("CFLAGS", "")
    setglobal ENV.CFLAGS = "${CFLAGS} -fPIC"

    ./configure \
        --prefix=/usr

    make
    make DESTDIR=$dest install
}
