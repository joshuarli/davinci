#!/usr/local/bin/ysh

var name    = 'zlib'
var ver     = '1.3.2'
var rel     = '4'
var deps    = []
var mkdeps  = ['zig', 'make']

var sources = ['https://zlib.net/fossils/zlib-VERSION.tar.gz']
var checksums = ['bb329a0a2cd0274d05519d61c667c062e06990d72e125ee2dfa8de64f0119d16']

proc build(dest) {
    var CFLAGS = ENV => get("CFLAGS", "")
    setglobal ENV.CFLAGS = "${CFLAGS} -fPIC"

    ./configure \
        --prefix=/usr

    make
    make DESTDIR=$dest install
}
