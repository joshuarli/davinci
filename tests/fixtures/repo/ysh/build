#!/bin/sh
set -e
dest="$1"

# Detect musl target triple from architecture.
MUSL_TARGET="$(uname -m)-linux-musl"

# Static build targeting musl — no glibc/libstdc++ runtime deps.
# oils is a C++ project that passes -std=c++11 to CC on .c files.
# Both cc and c++ force -xc++ to treat all source as C++.
cat > /usr/bin/cc <<EOF
#!/bin/sh
exec zig c++ -target $MUSL_TARGET -xc++ "\$@"
EOF
cp /usr/bin/cc /usr/bin/c++
chmod +x /usr/bin/cc /usr/bin/c++

echo "=== cc wrapper ===" >&2
cat /usr/bin/cc >&2
echo "=== cc test ===" >&2
echo 'int main(){}' > /tmp/_test.c
/usr/bin/cc -std=c++11 -c /tmp/_test.c -o /dev/null 2>&1 && echo "cc OK" >&2 || echo "cc FAIL" >&2

LDFLAGS='' ./configure --without-readline
LDFLAGS='' _build/oils.sh

mkdir -p "${dest}/usr/local/bin"
cp _bin/cxx-opt-sh/oils-for-unix "${dest}/usr/local/bin/oils-for-unix"
ln -s oils-for-unix "${dest}/usr/local/bin/osh"
ln -s oils-for-unix "${dest}/usr/local/bin/ysh"
