#!/usr/local/bin/ysh

var name    = 'sudo-rs'
var ver     = '0.2.13'
var rel     = '1'
var deps    = ['glibc', 'linux-pam']
var mkdeps  = ['cargo']

var sources = ['https://github.com/trifectatechfoundation/sudo-rs/archive/refs/tags/vVERSION.tar.gz']
var checksums = ['79becefc504d14ffccc7cab18d42f8d892e78b2d13d9c5bb887c5f02a2721eaf']

proc build(dest) {

    cargo build --release

    install -Dm4755 target/release/sudo "${dest}/usr/bin/sudo"
    install -Dm4755 target/release/su "${dest}/usr/bin/su"
    install -Dm755 target/release/visudo "${dest}/usr/bin/visudo"

    mkdir -p "${dest}/etc" "${dest}/etc/pam.d"

    # NOPASSWD for wheel — josh has no password in the dev VM.
    cat > "${dest}/etc/sudoers" << 'EOF'
root ALL=(ALL:ALL) ALL
%wheel ALL=(ALL:ALL) NOPASSWD: ALL
EOF
    chmod 440 "${dest}/etc/sudoers"

    # PAM configuration for sudo-rs.  Without these files libpam aborts with
    # "Critical error" before sudo even reads sudoers.  pam_permit lets all
    # auth/account checks pass; pam_unix records the session in wtmp.
    for svc in (:| sudo sudo-rs su |) {
        cat > "${dest}/etc/pam.d/${svc}" << 'EOF'
auth     sufficient  pam_permit.so
account  sufficient  pam_permit.so
password sufficient  pam_permit.so
session  optional    pam_unix.so
EOF
    }
}
