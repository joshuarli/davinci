#!/usr/local/bin/ysh

var dest = ARGV[0]

muon setup \
    -Dprefix=/usr \
    -Dlibdir=lib \
    -Dsysconfdir=/etc \
    -Ddocs=auto \
    -Di18n=auto \
    -Daudit=disabled \
    -Dselinux=disabled \
    -Deconf=disabled \
    -Dnis=disabled \
    -Dlogind=disabled \
    -Dopenssl=disabled \
    -Dpam_userdb=disabled \
    -Dexamples=false \
    -Dpam_lastlog=disabled \
    -Dxtests=false \
    -Dlckpwdf=false \
    build

samu -C build
DESTDIR=$dest muon -C build install
