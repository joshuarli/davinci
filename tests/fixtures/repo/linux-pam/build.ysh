#!/usr/local/bin/ysh

var dest = ARGV[0]

# Patch the version script before configure: lld requires all symbols listed
# in version scripts to be defined. The original lists all 6 pam_sm_* symbols
# but PAM modules only implement the subset they need. Replace with a wildcard.
cp modules.map modules/modules.map

# glibc's libcrypt.so uses GLIBC_PRIVATE symbols internally.
# lld rejects this by default; --allow-shlib-undefined permits it.
setglobal ENV.LDFLAGS = "-Wl,--allow-shlib-undefined"

muon setup \
    -Dprefix=/usr \
    -Dlibdir=lib \
    -Dsysconfdir=/etc \
    -Ddocs=auto \
    -Di18n=auto \
    -Daudit=disabled \
    -Dselinux=disabled \
    -Deconf=disabled \
    -Dnis=disabled \
    -Dlogind=disabled \
    -Dopenssl=disabled \
    -Dpam_userdb=disabled \
    -Dexamples=false \
    -Dpam_lastlog=disabled \
    -Dxtests=false \
    -Dlckpwdf=false \
    build

# Patch the version script: lld requires all symbols in version scripts to
# exist. GNU ld silently ignores missing ones. The patched file uses a
# wildcard so lld doesn't fail on modules that implement only a subset.
# -k0: keep going even if some targets (test binaries) fail.
# The pam_warn tst-* binary fails due to an empty lib arg from muon,
# but the actual PAM libraries and modules build fine.
samu -k0 -C build || true
DESTDIR=$dest muon -C build install
