#!/usr/local/bin/ysh

var dest = ARGV[0]

var uid = $(id -u)
var gid = $(id -g)

env BINOWN=$uid BINGRP=$gid \
./configure \
    --prefix=/usr \
    --with-shadow \
    --with-timestamp \
    --without-pam

make
make DESTDIR=$dest install

mkdir -p "${dest}/etc"
cp -f doas.conf "${dest}/etc"
chmod 600 "${dest}/etc/doas.conf"
