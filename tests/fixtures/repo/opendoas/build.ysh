#!/usr/local/bin/ysh

var dest = ARGV[0]

var uid = $(id -u)
var gid = $(id -g)

env BINOWN=$uid BINGRP=$gid \
./configure \
    --prefix=/usr \
    --with-shadow \
    --with-timestamp \
    --without-pam

# Use bison directly — the yacc wrapper has hardcoded paths that break
# when bison is installed under KOMINKA_ROOT.
# Also set BISON_PKGDATADIR so bison finds m4sugar under KOMINKA_ROOT.
make YACC='bison -y' BISON_PKGDATADIR="${KOMINKA_ROOT}/usr/share/bison"
make DESTDIR=$dest install

mkdir -p "${dest}/etc"
cp -f doas.conf "${dest}/etc"
chmod 600 "${dest}/etc/doas.conf"
