#!/usr/local/bin/ysh

var name    = 'xz'
var ver     = '5.8.3'
var rel     = '2'
var deps    = []
var mkdeps  = ['zig', 'make']

var sources = ['https://github.com/tukaani-project/xz/releases/download/vVERSION/xz-VERSION.tar.xz']
var checksums = ['fff1ffcf2b0da84d308a14de513a1aa23d4e9aa3464d17e64b9714bfdd0bbfb6']

proc build(dest) {

    ./configure \
        --prefix=/usr \
        --disable-doc \
        --disable-nls

    make
    make DESTDIR=$dest install
}
