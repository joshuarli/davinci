#!/bin/sh -ef

busybox mkdir -p \
    "$1/usr/bin" \
    "$1/usr/share/doc/kominka/init"

busybox cp -R etc "$1"
busybox cp -R lib "$1/usr/lib"

# Rebrand KISS -> Kominka.
busybox sed -i 's/KISS/Kominka/g' "$1/usr/lib/init/rc.boot"

# Silence 'command -v' stderr for shells that print "not found" (osh).
busybox sed -i 's|command -v \([a-z]*\) >/dev/null|command -v \1 >/dev/null 2>\&1|g' "$1/usr/lib/init/rc.boot"

# Skip fsck when no filesystem-specific helpers are installed.
busybox sed -i '/fsck -ATat/s/^/command -v fsck.ext4 >\/dev\/null 2>\&1 \&\& /' "$1/usr/lib/init/rc.boot"

# Disable warning as CFLAGS must work this way.
# shellcheck disable=2086
for bin in kpow kall; do
    "$CC" -o "$1/usr/bin/$bin" "bin/$bin.c" $CFLAGS
    busybox cp -f "bin/$bin.c" "$1/usr/share/doc/kominka/init/$bin.c"
done
