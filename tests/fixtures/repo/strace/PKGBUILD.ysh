#!/usr/local/bin/ysh

var name    = 'strace'
var ver     = '6.19'
var rel     = '2'
var deps    = ['glibc']
var mkdeps  = ['zig', 'make', 'linux-headers']

var sources = ['https://strace.io/files/VERSION/strace-VERSION.tar.xz']
var checksums = ['e076c851eec0972486ec842164fdc54547f9d17abd3d1449de8b120f5d299143']

proc build(dest) {

    ./configure \
        --prefix=/usr \
        --disable-mpers

    make
    make install
}
