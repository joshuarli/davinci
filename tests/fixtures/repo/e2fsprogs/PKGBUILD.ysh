#!/usr/local/bin/ysh

var name    = 'e2fsprogs'
var ver     = '1.47.4'
var rel     = '4'
var deps    = ['glibc']
var mkdeps  = ['zig', 'make']

var sources = ['https://mirrors.edge.kernel.org/pub/linux/kernel/people/tytso/e2fsprogs/vVERSION/e2fsprogs-VERSION.tar.xz']
var checksums = ['fd5bf388cbdbe006a3d3b318d983b2948382440acc85a87f1e7d108653e8db0b']

proc build(dest) {

    ./configure \
        --prefix=/usr \
        --sbindir=/usr/bin \
        --sysconfdir=/etc \
        --enable-symlink-install \
        --enable-libuuid \
        --enable-libblkid \
        --disable-nls \
        --disable-uuidd \
        --disable-fsck \
        --disable-elf-shlibs

    make

    var install_args = [
        'MKDIR_P=mkdir -p',
        'BLKID_MAN=',
        'BLKID_PROG=',
        'FINDFS_LINK=',
        'FINDFS_MAN=',
        'UMANPAGES=chattr.1 lsattr.1',
        'UPROGS=chattr lsattr',
    ]

    for p in (:| debugfs e2fsck lib/e2p lib/et lib/ext2fs lib/ss misc resize scrub |) {
        make -C $p DESTDIR=$dest @install_args install
    }
}
