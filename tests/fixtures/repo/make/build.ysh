#!/usr/local/bin/ysh

var dest = ARGV[0]
var CFLAGS = ENV => get("CFLAGS", "")
setglobal ENV.CFLAGS = "${CFLAGS} -static -Wno-error -Wno-int-conversion -Wno-implicit-function-declaration"

./configure \
    --prefix=/usr \
    --disable-nls

# Fix gnulib compat: replace all K&R-style zero-arg prototypes that
# conflict with strict POSIX declarations in modern libc headers.
find . \( -name '*.c' -o -name '*.h' \) -exec sed -i \
    -e 's/extern char \*getenv ();/\/* getenv *\//' \
    -e 's/^extern int getopt ();/\/* getopt *\//' \
    {} +

make
make DESTDIR=$dest install
