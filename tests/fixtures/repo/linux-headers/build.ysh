#!/usr/local/bin/ysh

var dest = ARGV[0]
var CC = ENV => get("CC", "cc")
# Use system gcc for host tools when available (zig-compiled tools crash under QEMU).
var HOSTCC = CC
try { command -v gcc >/dev/null 2>&1 }
if ! failed { setvar HOSTCC = 'gcc' }

make HOSTCC=$HOSTCC headers

# The headers require rsync for installation. This does the equivalent
# using find, mkdir and cp.
find usr/include -name '*.h' -type f | while read -r file {
    mkdir -p "${dest}/${file%/*}"
    cp -f $file "${dest}/${file}"
}
