#!/usr/local/bin/ysh

var name    = 'kominka'
var ver     = '5.5.28'
var rel     = '1'
var deps    = []
var mkdeps  = []

var sources = ['https://github.com/kisslinux/kiss/archive/VERSION.tar.gz']
var checksums = [
    'c592788aecb7e39b88bb3d030cb35b3b040392627520e6978dc15173154f2d50',
    'e8549203a55bef2cf7c900814e7c9c694beebe0178e42d82a0a873bf8baea522',
]

proc build(dest) {

    mkdir -p \
        "${dest}/usr/bin" \
        "${dest}/usr/share/doc/kominka"

    cp -f pm @[glob('contrib/*')] "${dest}/usr/bin"

    var docs = @[glob('docs/site/*.txt')]
    if (len(docs) > 0) {
        cp -f @docs "${dest}/usr/share/doc/kominka"
    }

    if test -d docs/site/wiki {
        cp -rf docs/site/wiki "${dest}/usr/share/doc/kominka"
    }

    rm -f \
        "${dest}/usr/share/doc/kominka/README.txt" \
        "${dest}/usr/share/doc/kominka/post.txt" \
        "${dest}/usr/share/doc/kominka/tidbits.txt"
}
