#!/usr/local/bin/ysh

var dest = ARGV[0]

busybox mkdir -p "${dest}/usr/bin" "${dest}/usr/lib"
busybox cp -a zig "${dest}/usr/bin/"
busybox cp -a lib "${dest}/usr/lib/zig"

# cc/c++ wrappers using native target (system glibc).
# cc detects c++ flags (-std=c++*) and upgrades to zig c++ automatically.
# Some build systems (oils) pass -std=c++11 to CC instead of CXX.
write -- '#!/bin/sh
mode=cc
for a in "$@"; do case "$a" in -std=c++*) mode="c++";; esac; done
exec zig $mode "$@"' > "${dest}/usr/bin/cc"
write -- '#!/bin/sh' 'exec zig c++ "$@"' > "${dest}/usr/bin/c++"
# ld — zig's bundled lld, exposed directly.
write -- '#!/bin/sh' 'exec zig ld.lld "$@"' > "${dest}/usr/bin/ld"
# ar wrapper — autotools and make need it.
write -- '#!/bin/sh' 'exec zig ar "$@"' > "${dest}/usr/bin/ar"
# ranlib is a no-op with zig's ar.
write -- '#!/bin/sh' 'exec zig ranlib "$@"' > "${dest}/usr/bin/ranlib"
# objcopy/strip wrappers.
write -- '#!/bin/sh' 'exec zig objcopy "$@"' > "${dest}/usr/bin/objcopy"
# strip wrapper — translates GNU strip flags to zig objcopy equivalents.
# Silently drops unsupported flags (--remove-section, -R, -o, etc.).
write -- '#!/bin/sh
flags="" files="" skip=""
for a in "$@"; do
    if [ -n "$skip" ]; then skip=""; continue; fi
    case "$a" in
        -s|-g|-S) flags="$flags --strip-debug" ;;
        -o|-R|-N|-K) skip=1 ;;
        --remove-section=*|--strip-unneeded|-p|-w) ;;
        -*) ;;
        *) files="$files $a" ;;
    esac
done
for f in $files; do
    busybox cp "$f" "$f.bak"
    zig objcopy $flags "$f" "$f" 2>/dev/null || { busybox cp "$f.bak" "$f"; }
    busybox rm -f "$f.bak"
done' > "${dest}/usr/bin/strip"
# nm — tiny ELF symbol lister (needed by libtool).
"${dest}/usr/bin/zig" cc -o "${dest}/usr/bin/nm" nm.c
busybox chmod +x "${dest}/usr/bin/cc" "${dest}/usr/bin/c++" "${dest}/usr/bin/ld" \
         "${dest}/usr/bin/ar" "${dest}/usr/bin/ranlib" "${dest}/usr/bin/objcopy" \
         "${dest}/usr/bin/strip"
