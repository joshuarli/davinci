#!/usr/local/bin/ysh

var name    = 'cmake'
var ver     = '3.22.1'
var rel     = '1'
var deps    = ['glibc']
var mkdeps  = ['make']

var sources = [
    'https://cmake.org/files/vMAJOR.MINOR/cmake-VERSION.tar.gz',
    'patches/cmake-no-execinfo.patch',
]
var checksums = [
    '0e998229549d7b3f368703d20e248e7ee1f853910d42704aa87918c213ea82c0',
    '93f5582efd076673f9bcb3e639bd594e378954a5a3130e5921027ede23c3325c',
]

proc build(dest) {

    var nproc = $(nproc)

    # Bootstrap build using bundled dependencies.
    # No --system-* flags: uses bundled curl, expat, zlib, bzip2, etc.
    # This avoids needing those as separate Kominka packages for the initial bootstrap.
    ./configure --prefix=/usr --parallel=$nproc -- -DCMAKE_USE_OPENSSL=OFF
    make -j$nproc
    make DESTDIR=$dest install
}
