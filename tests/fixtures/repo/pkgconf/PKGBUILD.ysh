#!/usr/local/bin/ysh

var name    = 'pkgconf'
var ver     = '1.8.0'
var rel     = '1'
var deps    = ['glibc']
var mkdeps  = []

var sources = ['https://distfiles.ariadne.space/pkgconf/pkgconf-VERSION.tar.xz']
var checksums = ['ef9c7e61822b7cb8356e6e9e1dca58d9556f3200d78acab35e4347e9d4c2bbaf']

proc build(dest) {

    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc

    make
    make DESTDIR=$dest install

    ln -s pkgconf "${dest}/usr/bin/pkg-config"

    # Remove documentation.
    rm -rf "${dest}/usr/share/doc"
}
