#!/usr/local/bin/ysh

var name    = 'libevent'
var ver     = '2.1.12'
var rel     = '1'
var deps    = ['zlib']
var mkdeps  = ['zig', 'make']

var sources = ['https://github.com/libevent/libevent/releases/download/release-VERSION-stable/libevent-VERSION-stable.tar.gz']
var checksums = ['92e6de1be9ec176428fd2367677e61ceffc2ee1cb119035037a27d346b0403bb']

proc build(dest) {
    ./configure \
        --prefix=/usr \
        --enable-shared \
        --disable-openssl \
        --disable-samples \
        --disable-libevent-regress

    make
    make DESTDIR=$dest install
}
