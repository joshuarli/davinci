#!/bin/sh -e
# cargo — precompiled Rust toolchain (rustc, cargo, std) from rust-lang.org.
dest=$1
arch=$(uname -m)

# Install libgcc_s.so.1 — the prebuilt rustc needs GCC's unwinding runtime.
# Bundled from Debian bookworm's libgcc-s1 package (GCC 12).
install -Dm755 "libgcc_s-${arch}.so.1" "$dest/usr/lib/libgcc_s.so.1"

# Compat symlinks: libdl, libpthread, librt merged into libc in glibc 2.34+
# but the prebuilt rustc still links against them.
for lib in libdl.so.2 libpthread.so.0 librt.so.1; do
    ln -sf libc.so.6 "$dest/usr/lib/$lib"
done

# Binaries
mkdir -p "$dest/usr/bin"
cp rustc/bin/rustc "$dest/usr/bin/"
cp rustc/bin/rustdoc "$dest/usr/bin/"
cp cargo/bin/cargo "$dest/usr/bin/"

# Libraries (rustc libs + std)
mkdir -p "$dest/usr/lib"
cp -a rustc/lib/* "$dest/usr/lib/"
for d in rust-std-*/lib/*; do
    cp -a "$d" "$dest/usr/lib/" 2>/dev/null || true
done
