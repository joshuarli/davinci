#!/usr/local/bin/ysh

var dest = ARGV[0]

var CC = ENV => get("CC", "cc")
var CXX = ENV => get("CXX", "c++")

cmake -GNinja -B build \
    -DCMAKE_BUILD_TYPE=Release \
    -DBUILD_SHARED_LIBS=ON \
    -DBUILD_TESTING=OFF \
    -DCMAKE_C_COMPILER=$CC \
    -DCMAKE_CXX_COMPILER=$CXX
ninja -C build

busybox mkdir -p "${dest}/usr/lib/pkgconfig" "${dest}/usr/include" "${dest}/etc/ssl"

busybox cp -r include/openssl "${dest}/usr/include/"
busybox cp build/libssl.so "${dest}/usr/lib/"
busybox cp build/libcrypto.so "${dest}/usr/lib/"

busybox cp -f update-certdata.sh "${dest}/etc/ssl"

# pkg-config files for curl and other consumers.
write -- '''prefix=/usr
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libssl
Description: BoringSSL
Version: 0.0.0
Libs: -L${libdir} -lssl -lcrypto
Cflags: -I${includedir}''' > "${dest}/usr/lib/pkgconfig/libssl.pc"

write -- '''prefix=/usr
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libcrypto
Description: BoringSSL
Version: 0.0.0
Libs: -L${libdir} -lcrypto
Cflags: -I${includedir}''' > "${dest}/usr/lib/pkgconfig/libcrypto.pc"

write -- '''prefix=/usr

Name: openssl
Description: BoringSSL (OpenSSL-compatible)
Version: 0.0.0
Requires: libssl libcrypto''' > "${dest}/usr/lib/pkgconfig/openssl.pc"
