#!/usr/local/bin/ysh

var dest = ARGV[0]
var _kr = ENV => get("KOMINKA_ROOT", "")
var ssl_prefix = "${_kr}/usr"

# Ensure configure can find headers and libraries in KOMINKA_ROOT.
var _cflags = ENV => get("CFLAGS", "-O2 -DNDEBUG") ++ " -Wno-error"
var _ldflags = ENV => get("LDFLAGS", "")
if (_kr !== '' and _kr !== '/') {
    setvar _cflags = "${_cflags} -I${_kr}/usr/include"
    setvar _ldflags = "${_ldflags} -L${_kr}/usr/lib"
}

CFLAGS=$_cflags LDFLAGS=$_ldflags ./configure \
    --prefix=/usr \
    --enable-ipv6 \
    --enable-unix-sockets \
    --enable-hidden-symbols \
    --disable-manual \
    --disable-ldap \
    --disable-ares \
    --with-openssl=$ssl_prefix \
    --with-pic \
    --with-ca-fallback \
    --without-librtmp \
    --without-icu \
    --without-libpsl \
    --without-libidn \
    --without-libidn2 \
    --without-brotli \
    --without-zstd

make
make DESTDIR=$dest install
