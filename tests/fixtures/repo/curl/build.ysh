#!/usr/local/bin/ysh

var dest = ARGV[0]
var _kr = ENV => get("KOMINKA_ROOT", "")
var ssl_prefix = "${_kr}/usr"

# BoringSSL ships openssl/time.h (a compat shim).  curl's configure adds
# -isystem .../openssl which makes that file shadow the real <time.h>.
# Move it aside so struct tm / time() are found in glibc's header.
if test -f "${_kr}/usr/include/openssl/time.h" {
    mv "${_kr}/usr/include/openssl/time.h" "${_kr}/usr/include/openssl/time.h.aside"
}

var _cflags = ENV => get("CFLAGS", "-O2 -DNDEBUG") ++ " -Wno-error"
var _ldflags = ENV => get("LDFLAGS", "")
if (_kr !== '' and _kr !== '/') {
    setvar _ldflags = "${_ldflags} -L${_kr}/usr/lib"
}

CFLAGS=$_cflags LDFLAGS=$_ldflags \
    PKG_CONFIG_PATH="${_kr}/usr/lib/pkgconfig" \
    ./configure \
    --prefix=/usr \
    --enable-ipv6 \
    --enable-unix-sockets \
    --enable-hidden-symbols \
    --disable-manual \
    --disable-ldap \
    --disable-ares \
    --with-openssl=$ssl_prefix \
    --with-pic \
    --with-ca-fallback \
    --without-librtmp \
    --without-icu \
    --without-libpsl \
    --without-libidn \
    --without-libidn2 \
    --without-brotli \
    --without-zstd

make
make DESTDIR=$dest install
