#!/bin/sh -e

# BoringSSL ships openssl/time.h (a compat shim).  curl's configure adds
# -isystem .../openssl which makes that file shadow the real <time.h>.
# Move it aside so struct tm / time() are found in glibc's header.
if [ -f "${KOMINKA_ROOT}/usr/include/openssl/time.h" ]; then
    mv "${KOMINKA_ROOT}/usr/include/openssl/time.h" \
       "${KOMINKA_ROOT}/usr/include/openssl/time.h.aside"
fi

CFLAGS="${CFLAGS:--O2 -DNDEBUG} -Wno-error"
LDFLAGS="${LDFLAGS:-}"

if [ -n "$KOMINKA_ROOT" ] && [ "$KOMINKA_ROOT" != "/" ]; then
    LDFLAGS="${LDFLAGS} -L${KOMINKA_ROOT}/usr/lib"
fi
export CFLAGS LDFLAGS

./configure \
    --prefix=/usr \
    --enable-ipv6 \
    --enable-unix-sockets \
    --enable-hidden-symbols \
    --disable-manual \
    --disable-ldap \
    --disable-ares \
    --with-openssl="${KOMINKA_ROOT:-}/usr" \
    --with-pic \
    --with-ca-fallback \
    --without-librtmp \
    --without-icu \
    --without-libpsl \
    --without-libidn \
    --without-libidn2 \
    --without-brotli \
    --without-zstd

make
make DESTDIR="$1" install
