#!/usr/local/bin/ysh

var dest = ARGV[0]
var CC = ENV => get("CC", "cc")
var LDFLAGS = ENV => get("LDFLAGS", "")
var CFLAGS = ENV => get("CFLAGS", "")
var CPPFLAGS = ENV => get("CPPFLAGS", "")

make PREFIX=/usr
make PREFIX=/usr install

mkdir -p "${dest}/usr/bin"

$CC $LDFLAGS $CFLAGS $CPPFLAGS \
    -o "${dest}/usr/bin/libudev-zero-helper" contrib/helper.c
