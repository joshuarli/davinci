#!/usr/local/bin/ysh

var name    = 'libudev-zero'
var ver     = '1.0.3'
var rel     = '2'
var deps    = []
var mkdeps  = ['linux-headers']

var sources = ['https://github.com/illiliti/libudev-zero/archive/refs/tags/VERSION.tar.gz']
var checksums = ['0bd89b657d62d019598e6c7ed726ff8fed80e8ba092a83b484d66afb80b77da5']

proc build(dest) {
    var CC = ENV => get("CC", "cc")
    var LDFLAGS = ENV => get("LDFLAGS", "")
    var CFLAGS = ENV => get("CFLAGS", "")
    var CPPFLAGS = ENV => get("CPPFLAGS", "")

    make PREFIX=/usr
    make PREFIX=/usr install

    mkdir -p "${dest}/usr/bin"

    $CC $LDFLAGS $CFLAGS $CPPFLAGS \
        -o "${dest}/usr/bin/libudev-zero-helper" contrib/helper.c
}
