#!/usr/local/bin/ysh

var name    = 'sqlite'
var ver     = '3.53.0'
var rel     = '2'
var deps    = ['zlib']
var mkdeps  = []

var sources = ['https://www.sqlite.org/2026/sqlite-autoconf-3530000.tar.gz']
var checksums = ['851e9b38192fe2ceaa65e0baa665e7fa06230c3d9bd1a6a9662d02380d73365a']

proc build(dest) {
    var CPPFLAGS = ENV => get("CPPFLAGS", "")

    env CPPFLAGS="${CPPFLAGS} -DSQLITE_ENABLE_COLUMN_METADATA=1" \
    ./configure \
        --prefix=/usr \
        --enable-threadsafe \
        --enable-dynamic-extensions \
        --enable-fts5 \
        ac_cv_search_readline=no

    make
    make install
}
