#!/usr/local/bin/ysh

var name    = 'sqlite'
var ver     = '3.37.0'
var rel     = '1'
var deps    = ['zlib']
var mkdeps  = []

var sources = ['https://www.sqlite.org/2021/sqlite-autoconf-3370000.tar.gz']
var checksums = ['731a4651d4d4b36fc7d21db586b2de4dd00af31fd54fb5a9a4b7f492057479f7']

proc build(dest) {
    var CPPFLAGS = ENV => get("CPPFLAGS", "")

    env CPPFLAGS="${CPPFLAGS} -DSQLITE_ENABLE_COLUMN_METADATA=1" \
    ./configure \
        --prefix=/usr \
        --enable-threadsafe \
        --enable-dynamic-extensions \
        --enable-fts5 \
        ac_cv_search_readline=no

    make
    make install
}
