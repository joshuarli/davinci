#!/usr/local/bin/ysh

var dest = ARGV[0]
var ARCH = $(uname -m)
var CC = ENV => get("CC", "cc")
var srcdir = $(pwd)

./configure \
    --prefix=/usr \
    --syslibdir=/usr/lib

make
make DESTDIR=$dest install

mkdir -p "${dest}/usr/bin"
ln -s "/usr/lib/ld-musl-${ARCH}.so.1" "${dest}/usr/bin/ldd"

# Fix incorrect symlink to libc.so.
ln -sf libc.so "${dest}/usr/lib/ld-musl-${ARCH}.so.1"

# Install BSD compatibility headers (from source directory).
cp -f "${srcdir}/cdefs.h" "${srcdir}/queue.h" "${srcdir}/tree.h" \
    "${dest}/usr/include/sys"

# Install getconf.
$CC "${srcdir}/getconf.c" -o "${dest}/usr/bin/getconf"
$CC "${srcdir}/getent.c"  -o "${dest}/usr/bin/getent"
