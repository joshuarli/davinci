#!/usr/local/bin/ysh

var dest = ARGV[0]
var CC = ENV => get("CC", "cc")

cd runit-2.1.2

# Override compiler and linker.
# -D_GNU_SOURCE exposes setgroups() in glibc headers.
# -Wno-implicit-function-declaration tolerates runit's old C style.
write -- "${CC} -O2 -Wall -D_GNU_SOURCE -Wno-implicit-function-declaration -Wno-incompatible-pointer-types" > src/conf-cc
write -- "${CC} -s"        > src/conf-ld

# runit defaults to -static; remove it for dynamic linking.
busybox sed -i 's/ -static//g' src/Makefile

# Build using runit's own build system.
package/compile

# Install supervision binaries.
busybox mkdir -p "${dest}/usr/bin"
for bin in (:| chpst runsv runsvdir sv svlogd |) {
    busybox cp -f "command/${bin}" "${dest}/usr/bin/"
}
