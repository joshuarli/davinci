#!/usr/local/bin/ysh

var name    = 'bzip2'
var ver     = '1.0.8'
var rel     = '1'
var deps    = []
var mkdeps  = []

var sources = ['https://sourceware.org/pub/bzip2/bzip2-VERSION.tar.gz']
var checksums = ['ab5a03176ee106d3f0fa90e381da478ddae405918153cca248e682cd0c4a2269']

proc build(dest) {
    var CC = ENV => get("CC", "cc")
    var CFLAGS = ENV => get("CFLAGS", "")
    var LDFLAGS = ENV => get("LDFLAGS", "")

    # CC is passed as a make variable (string), not as positional args.
    make CC="$CC $CFLAGS -fPIC $LDFLAGS" -f Makefile-libbz2_so
    make CC="$CC $CFLAGS -fPIC $LDFLAGS" bzip2

    mkdir -p \
        "${dest}/usr/bin" \
        "${dest}/usr/lib" \
        "${dest}/usr/share/man/man1" \
        "${dest}/usr/include"

    cp -f \
        bzip2 \
        bzdiff \
        bzgrep \
        bzmore \
        "${dest}/usr/bin"

    cp -f \
        libbz2.so.1.0.8 \
        libbz2.a \
        "${dest}/usr/lib"

    cp -f bzip2.1 "${dest}/usr/share/man/man1"
    cp -f bzlib.h "${dest}/usr/include"

    ln -sf libbz2.so.1.0.8 "${dest}/usr/lib/libbz2.so"
    ln -sf libbz2.so.1.0.8 "${dest}/usr/lib/libbz2.so.1"
    ln -sf libbz2.so.1.0.8 "${dest}/usr/lib/libbz2.so.1.0"
    ln -sf bzip2 "${dest}/usr/bin/bunzip2"
    ln -sf bzip2 "${dest}/usr/bin/bzcat"
}
