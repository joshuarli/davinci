#!/usr/local/bin/ysh

var dest = ARGV[0]
var CC = ENV => get("CC", "cc")
var CFLAGS = ENV => get("CFLAGS", "")
var LDFLAGS = ENV => get("LDFLAGS", "")

# CC is passed as a make variable (string), not as positional args.
make CC="$CC $CFLAGS -fPIC $LDFLAGS" -f Makefile-libbz2_so
make CC="$CC $CFLAGS -fPIC $LDFLAGS" bzip2

busybox mkdir -p \
    "${dest}/usr/bin" \
    "${dest}/usr/lib" \
    "${dest}/usr/share/man/man1" \
    "${dest}/usr/include"

busybox cp -f \
    bzip2 \
    bzdiff \
    bzgrep \
    bzmore \
    "${dest}/usr/bin"

busybox cp -f \
    libbz2.so.1.0.8 \
    libbz2.a \
    "${dest}/usr/lib"

busybox cp -f bzip2.1 "${dest}/usr/share/man/man1"
busybox cp -f bzlib.h "${dest}/usr/include"

busybox ln -sf libbz2.so.1.0.8 "${dest}/usr/lib/libbz2.so"
busybox ln -sf libbz2.so.1.0.8 "${dest}/usr/lib/libbz2.so.1"
busybox ln -sf libbz2.so.1.0.8 "${dest}/usr/lib/libbz2.so.1.0"
busybox ln -sf bzip2 "${dest}/usr/bin/bunzip2"
busybox ln -sf bzip2 "${dest}/usr/bin/bzcat"
