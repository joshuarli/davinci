#!/usr/local/bin/ysh

var dest = ARGV[0]

./Configure \
    --prefix=/usr \
    --openssldir=/etc/ssl \
    --libdir=lib \
    no-unit-test \
    shared \
    linux-generic64

make depend
make

make DESTDIR=$dest \
    install_sw \
    install_ssldirs \
    install_man_docs

cp -f update-certdata.sh "${dest}/etc/ssl"

# Libretls is LibreSSL's libtls library for OpenSSL.
cd libretls {
    ./configure \
        --prefix=/usr \
        --with-openssl="${dest}/usr"

    make
    make DESTDIR=$dest install
}
