#!/usr/local/bin/ysh

var name    = 'm4'
var ver     = '1.4.19'
var rel     = '1'
var deps    = ['glibc']
var mkdeps  = []

var sources = ['https://ftp.gnu.org/gnu/m4/m4-VERSION.tar.xz']
var checksums = ['63aede5c6d33b6d9b13511cd0be2cac046f2e70fd0a07aa9573a04a82783af96']

proc build(dest) {

    ./configure \
        --prefix=/usr

    # Fix gnulib _GL_ATTRIBUTE_NODISCARD incompatibility with newer GCC.
    find lib -name '*.h' -exec sed -i \
        's/^\(# *define _GL_ATTRIBUTE_NODISCARD\) .*/\1/' {} +

    make
    make DESTDIR=$dest install
}
